        <!-- Upper content boxes -->
        <mxCell id="15" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 查看系统自动排期&lt;br&gt;&#8226; 根据故障率调整计划&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 设备检查计划页&lt;br&gt;&#8226; BIM设备分布+甘特图&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 台账分散不一致&lt;br&gt;&#8226; 排期靠经验拍脑袋&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; 系统聚合数据推排期&lt;br&gt;&#8226; BIM可视发现盲区&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI预测高风险设备&lt;br&gt;&#8226; 智能排期多维度约束&lt;br&gt;&#8226; BIM空间可视化&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="315" y="190" width="200" height="300" as="geometry" />
        </mxCell>
        <mxCell id="16" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 查看异常上报推送&lt;br&gt;&#8226; 审AI判断结果&lt;br&gt;&#8226; 确认等级/维保单位&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 异常审核页&lt;br&gt;&#8226; 详情(多图+OCR+评分)&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 描述参差需反复沟通&lt;br&gt;&#8226; 担心AI误判导致事故&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; AI综合评分+依据展示&lt;br&gt;&#8226; 历史案例辅助判断&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI外观/OCR/声音分析&lt;br&gt;&#8226; 综合健康度评分(0-100)&lt;br&gt;&#8226; BIM定位打标异常设备&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="530" y="190" width="200" height="300" as="geometry" />
        </mxCell>
        <mxCell id="17" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 确认AI推荐维保单位&lt;br&gt;&#8226; 设定SLA时限&lt;br&gt;&#8226; 一键分派工单&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 工单创建页(自动预填)&lt;br&gt;&#8226; 维保推荐卡片(评分)&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 维保质量参差不齐&lt;br&gt;&#8226; 紧急不知最近可用人&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; 维保评分透明化&lt;br&gt;&#8226; GIS就近匹配+档期&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI智能推荐最优单位&lt;br&gt;&#8226; 维修方案匹配案例&lt;br&gt;&#8226; GIS就近匹配+实时档期&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="745" y="190" width="200" height="300" as="geometry" />
        </mxCell>
        <mxCell id="18" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 查看维修进度看板&lt;br&gt;&#8226; 接收超时预警&lt;br&gt;&#8226; 必要时电话督办&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 维修跟踪看板&lt;br&gt;&#8226; 工单时间线+超时标红&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 维保虚报进度难验证&lt;br&gt;&#8226; 多工单并行易遗漏&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; GPS+BIM到场验证防虚报&lt;br&gt;&#8226; 超时自动升级(30min)&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI到场时间GPS比对&lt;br&gt;&#8226; 超时自动升级机制&lt;br&gt;&#8226; BIM室内导航+安全标注&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="960" y="190" width="200" height="300" as="geometry" />
        </mxCell>
        <mxCell id="19" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 远程审核维修报告&lt;br&gt;&#8226; 查看AI图像比对结果&lt;br&gt;&#8226; 必要时现场功能测试&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 验收审核页(照片对比)&lt;br&gt;&#8226; AI参数验证结果&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 远程怕报喜不报忧&lt;br&gt;&#8226; 现场验收跨楼成本高&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; AI红框标注差异区域&lt;br&gt;&#8226; 仅低置信度需现场验收&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI图像比对标记差异&lt;br&gt;&#8226; 参数自动比对标准范围&lt;br&gt;&#8226; BIM现场定位验证&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="1175" y="190" width="200" height="300" as="geometry" />
        </mxCell>
        <mxCell id="20" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 查看设备健康度月报&lt;br&gt;&#8226; 分析故障趋势与热力&lt;br&gt;&#8226; 制定维保预算计划&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 健康度报告&lt;br&gt;&#8226; 故障趋势图+BIM热力&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 趋势靠记忆手工统计&lt;br&gt;&#8226; 预算分配无数据支撑&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; AI劣化预测提前预警&lt;br&gt;&#8226; ROI模拟辅助预算分配&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI设备劣化预测&lt;br&gt;&#8226; 异常模式识别&lt;br&gt;&#8226; BIM故障热力图+生命周期&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5fc;strokeColor=#9673a6;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
