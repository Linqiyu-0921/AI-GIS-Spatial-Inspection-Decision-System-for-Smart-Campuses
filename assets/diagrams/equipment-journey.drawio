        <!-- Lower content boxes -->
        <mxCell id="33" value="&lt;div style=&quot;padding:3px;font-size:10px;&quot;&gt;&lt;b&gt;Actions:&lt;/b&gt;&lt;br&gt;&#8226; 打开APP查看待检设备&lt;br&gt;&#8226; 确认检查时间和地点&lt;br&gt;&lt;br&gt;&lt;b&gt;Touchpoints:&lt;/b&gt;&lt;br&gt;&#8226; 设备检查列表&lt;br&gt;&#8226; 详情(检查清单+BIM位)&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#c00;&quot;&gt;Pain:&lt;/b&gt;&lt;br&gt;&#8226; 不清楚检查重点漏项&lt;br&gt;&#8226; 设备房位置难找&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#2a7a2a;&quot;&gt;Opportunity:&lt;/b&gt;&lt;br&gt;&#8226; 高风险设备标红提示&lt;br&gt;&#8226; BIM室内导航指路&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#7a2a9a;&quot;&gt;AI/GIS:&lt;/b&gt;&lt;br&gt;&#8226; AI预测标记高风险&lt;br&gt;&#8226; BIM楼层定位&lt;br&gt;&#8226; 室内导航路径规划&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#6c8ebf;fontSize=10;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
