<mxfile host="app.diagrams.net" modified="2026-05-14T00:00:00.000Z" agent="Claude Code" version="24.0.0" type="device">
  <diagram id="scenario-relationship" name="场景关联关系">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="2" value="&lt;b&gt;三大场景关联与联动关系&lt;/b&gt;" style="text;html=1;fontSize=20;fontColor=#1a1a2e;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="500" height="30" as="geometry" />
        </mxCell>
        <!-- ===== 三大场景 : left to right ===== -->
        <!-- 日常巡检 -->
        <mxCell id="10" value="&lt;b&gt;日常巡检&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;每日1-2次&lt;br&gt;路线驱动+GPS定位&lt;br&gt;通用图像识别+NLP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=15;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="220" height="90" as="geometry" />
        </mxCell>
        <!-- 设备检查 -->
        <mxCell id="20" value="&lt;b&gt;设备检查&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;周/月/季检&lt;br&gt;检查清单+BIM定位&lt;br&gt;外观识别+OCR+声音分析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=15;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="490" y="100" width="220" height="90" as="geometry" />
        </mxCell>
        <!-- 应急事件 -->
        <mxCell id="30" value="&lt;b&gt;应急事件&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;不定期&lt;br&gt;并行多线程+指挥中心&lt;br&gt;预案匹配+态势地图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=15;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="880" y="100" width="220" height="90" as="geometry" />
        </mxCell>
        <!-- Arrows between scenarios -->
        <!-- 日常巡检 → 设备检查 -->
        <mxCell id="11" value="&lt;div style=&quot;text-align:center;font-size:10px;line-height:14px;&quot;&gt;发现设备异常&lt;br&gt;→ 自动触发设备检查&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;fontColor=#6c8ebf;" edge="1" parent="1" source="10" target="20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 设备检查 → 应急事件 -->
        <mxCell id="21" value="&lt;div style=&quot;text-align:center;font-size:10px;line-height:14px;&quot;&gt;发现重大隐患&lt;br&gt;→ 自动触发应急事件&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;fontColor=#82b366;" edge="1" parent="1" source="20" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 应急事件 → 日常巡检 (curved return) -->
        <mxCell id="31" value="&lt;div style=&quot;text-align:center;font-size:10px;line-height:14px;&quot;&gt;复盘优化&lt;br&gt;→ 调整巡检计划&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;dashed=1;fontSize=10;fontColor=#b85450;exitX=0;exitY=1;entryX=1;entryY=1;" edge="1" parent="1" source="30" target="10">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="240" />
              <mxPoint x="210" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- ===== 数据回流: 分析引擎 ===== -->
        <!-- Arrows from 3 scenarios down to 分析引擎 -->
        <mxCell id="12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" edge="1" parent="1" source="10" target="40">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="20" target="40">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="32" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.8;entryY=0;" edge="1" parent="1" source="30" target="40">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 分析引擎 big box -->
        <mxCell id="40" value="&lt;b&gt;分析引擎 — 数据回流驱动自优化&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=15;fontSize=13;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="280" y="360" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="41" value="&lt;div style=&quot;text-align:center;padding:4px;font-size:10px;line-height:16px;&quot;&gt;&lt;b&gt;趋势预测&lt;/b&gt;&lt;br&gt;7天风险区域预测&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="400" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="42" value="&lt;div style=&quot;text-align:center;padding:4px;font-size:10px;line-height:16px;&quot;&gt;&lt;b&gt;异常检测&lt;/b&gt;&lt;br&gt;问题突增/漏检告警&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="450" y="400" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="43" value="&lt;div style=&quot;text-align:center;padding:4px;font-size:10px;line-height:16px;&quot;&gt;&lt;b&gt;热力聚类&lt;/b&gt;&lt;br&gt;DBSCAN空间聚类&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="400" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="44" value="&lt;div style=&quot;text-align:center;padding:4px;font-size:10px;line-height:16px;&quot;&gt;&lt;b&gt;优化建议&lt;/b&gt;&lt;br&gt;频次/路线/人员调整&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="750" y="400" width="120" height="50" as="geometry" />
        </mxCell>
        <!-- 分析引擎 输出箭头 back to scenarios -->
        <mxCell id="45" value="&lt;div style=&quot;text-align:center;font-size:10px;line-height:14px;&quot;&gt;更新巡检计划&lt;br&gt;调整检查频率&lt;br&gt;优化应急预案&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=10;fontColor=#9673a6;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="40" target="10">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="500" />
              <mxPoint x="210" y="500" />
              <mxPoint x="210" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="46" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="40" target="20">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="500" />
              <mxPoint x="600" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="47" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="40" target="30">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="500" />
              <mxPoint x="990" y="500" />
              <mxPoint x="990" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Bottom description -->
        <mxCell id="50" value="&lt;div style=&quot;text-align:left;padding:6px;font-size:11px;line-height:18px;&quot;&gt;&lt;b&gt;场景联动逻辑：&lt;/b&gt;&lt;br&gt;1. 日常巡检发现设备异常 → 自动触发设备检查场景&lt;br&gt;2. 设备检查发现重大隐患 → 自动触发应急事件流程&lt;br&gt;3. 应急事件处置完成 → 数据进入分析引擎 → 优化日常巡检/设备检查计划&lt;br&gt;4. 分析引擎发现趋势 → 反向调整所有场景的计划（自优化闭环）&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=8;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="800" height="120" as="geometry" />
        </mxCell>
        <!-- Legend -->
        <mxCell id="60" value="&lt;b&gt;图例&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="720" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="61" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:16px;&quot;&gt;━━━ 触发/传递数据流&lt;br&gt;╌╌╌ 数据回流/反馈&lt;br&gt;&lt;span style=&quot;background-color:#dae8fc;&quot;&gt; 日常巡检 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#d5e8d4;&quot;&gt; 设备检查 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#f8cecc;&quot;&gt; 应急事件 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#e1d5e7;&quot;&gt; 分析引擎 &lt;/span&gt;&lt;/div&gt;" style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="105" y="738" width="210" height="80" as="geometry" />
        </mxCell>
