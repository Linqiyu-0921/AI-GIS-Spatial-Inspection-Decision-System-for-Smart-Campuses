        <mxCell id="21" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;T+30s&lt;/b&gt; IoT读取水浸数据，确认漏水&lt;br&gt;&lt;i&gt;系统自动&lt;/i&gt;&lt;br&gt;&lt;b&gt;T+1min&lt;/b&gt; 视频联动AI确认大量漏水&lt;br&gt;&lt;i&gt;系统自动&lt;/i&gt;&lt;br&gt;&lt;b&gt;T+2min&lt;/b&gt; 巡检员到场拍照确认爆管&lt;br&gt;&lt;i&gt;巡检员&lt;/i&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;arcSize=6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
