        <!-- Separator line -->
        <mxCell id="8" value="" style="endArrow=none;startArrow=none;strokeColor=#ccc;strokeWidth=1;dashed=1;" edge="1" parent="1">
          <mxGeometry width="100" height="100" relative="1" as="geometry">
            <mxPoint x="150" y="200" as="sourcePoint" />
