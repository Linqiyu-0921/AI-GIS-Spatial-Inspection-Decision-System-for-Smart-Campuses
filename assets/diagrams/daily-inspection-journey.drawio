        <!-- Emotion level labels -->
        <mxCell id="4" value="😊 高" style="text;html=1;fontSize=11;fontColor=#2a7a2a;align=right;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="95" width="80" height="20" as="geometry" />
