        <!-- Title -->
        <mxCell id="2" value="&lt;div style=&quot;text-align:center;&quot;&gt;&lt;b style=&quot;font-size:18px;&quot;&gt;日常巡检用户旅程地图&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#666;&quot;&gt;视角：巡检员（张建国+李明辉混合）· 时间跨度：单日 08:00–17:30 · 目标：从接收任务到完成闭环&lt;/span&gt;&lt;/div&gt;" style="text;html=1;fontSize=18;fontColor=#1a1a2e;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="950" y="10" width="1000" height="45" as="geometry" />
