        <!-- ======= Column 4: ④ 工单 ======= -->
        <mxCell id="d4-label" value="&lt;b&gt;④ 工单分派&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=8;fontSize=11;fontStyle=1;" vertex="1" parent="layer-detail">
