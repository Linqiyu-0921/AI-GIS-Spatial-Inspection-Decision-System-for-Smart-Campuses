        <mxCell id="e-s3-title" value="&lt;b&gt;L3 最高级响应（P0 应急 / 重大安全事件）&lt;/b&gt;" style="text;html=1;fontSize=14;fontColor=#1a1a2e;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="20" y="582" width="1560" height="28" as="geometry" />
