        <!-- 6 response dimension boxes in 3x2 grid -->
        <!-- Row 1 -->
        <mxCell id="e-l3-1" value="&lt;b&gt;全员推送&lt;/b&gt;&lt;hr&gt;巡检员、管理层、指挥中心&lt;br&gt;安保、维保单位" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="630" width="470" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e-l3-2" value="&lt;b&gt;指挥中心接管&lt;/b&gt;&lt;hr&gt;统一调度所有资源&lt;br&gt;跨部门调度无需逐级审批" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="630" width="470" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e-l3-3" value="&lt;b&gt;自动拉群&lt;/b&gt;&lt;hr&gt;主管+经理自动拉群（企微/钉钉）&lt;br&gt;实时同步事件进展" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="630" width="500" height="70" as="geometry" />
        </mxCell>

        <!-- Row 2 -->
        <mxCell id="e-l3-4" value="&lt;b&gt;处置超时上报&lt;/b&gt;&lt;hr&gt;若处置超时仍未解决&lt;br&gt;自动上报园区负责人" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="720" width="470" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e-l3-5" value="&lt;b&gt;资源跨部门调度&lt;/b&gt;&lt;hr&gt;可跨部门调度人员、设备、物资&lt;br&gt;无需逐级审批" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="720" width="470" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e-l3-6" value="&lt;b&gt;态势地图同步&lt;/b&gt;&lt;hr&gt;态势地图实时同步至所有相关人员&lt;br&gt;确保信息透明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="720" width="500" height="70" as="geometry" />
