        <mxCell id="60" value="&lt;b&gt;⑥ 处置&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;处置人现场维修&lt;br&gt;AI方案推荐+到场验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="990" y="55" width="160" height="65" as="geometry" />
