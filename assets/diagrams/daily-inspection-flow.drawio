        <mxCell id="61" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;角色：&lt;/b&gt;处置人&lt;br&gt;&lt;b&gt;AI：&lt;/b&gt;方案推荐+到场验证&lt;br&gt;&lt;b&gt;GIS：&lt;/b&gt;导航指引+位置验证&lt;br&gt;&lt;b&gt;SLA：&lt;/b&gt;P1≤2h/P2≤24h&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="990" y="130" width="160" height="85" as="geometry" />
