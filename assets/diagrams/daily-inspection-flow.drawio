        <mxCell id="70" value="&lt;b&gt;⑦ 验收&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;巡检员现场复核&lt;br&gt;AI图像比对+质量评分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
