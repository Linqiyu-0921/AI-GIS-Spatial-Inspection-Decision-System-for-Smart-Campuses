        <mxCell id="101" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:16px;&quot;&gt;&lt;span style=&quot;background-color:#e6d5b0;&quot;&gt; 标准步骤 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#d5e8d4;&quot;&gt; 轻微当场闭环 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#ffe6cc;&quot;&gt; 严重工单流程 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#e1d5e7;&quot;&gt; 数据分析环节 &lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color:#f5f5f5;border:1px solid #999;&quot;&gt; 角色/AI/GIS/SLA &lt;/span&gt;&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;b&gt;SLA升级：&lt;/b&gt;超时30min→主管；超时1h→经理&lt;/div&gt;" style="text;html=1;fontSize=10;fontColor=#333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
