        <mxCell id="41" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;角色：&lt;/b&gt;系统+巡检员&lt;br&gt;&lt;b&gt;AI：&lt;/b&gt;严重程度预测&lt;br&gt;&lt;b&gt;GIS：&lt;/b&gt;复用定位数据&lt;br&gt;&lt;b&gt;SLA：&lt;/b&gt;≤30秒&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="160" height="85" as="geometry" />
