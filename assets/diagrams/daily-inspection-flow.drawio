          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- STEP 4: 分支判断 -->
        <mxCell id="40" value="&lt;b&gt;④ 分支判断&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;AI辅助判定严重等级&lt;br&gt;轻微当场闭环/严重走工单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="55" width="160" height="65" as="geometry" />
