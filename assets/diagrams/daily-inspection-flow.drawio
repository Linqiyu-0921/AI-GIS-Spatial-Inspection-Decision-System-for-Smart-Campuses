  <diagram id="daily-inspection" name="日常巡检流程">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="2" value="&lt;b&gt;日常巡检全流程 — 八步闭环&lt;/b&gt;" style="text;html=1;fontSize=20;fontColor=#1a1a2e;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="600" y="10" width="500" height="30" as="geometry" />
        </mxCell>
        <!-- STEP 1: 计划编排下发 -->
        <mxCell id="10" value="&lt;b&gt;① 计划编排下发&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;每日自动生成巡检计划&lt;br&gt;AI优化路线，GIS覆盖分析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="11" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;角色：&lt;/b&gt;管理层/巡检员&lt;br&gt;&lt;b&gt;AI：&lt;/b&gt;预测分析+路线优化&lt;br&gt;&lt;b&gt;GIS：&lt;/b&gt;覆盖分析+空间可视化&lt;br&gt;&lt;b&gt;SLA：&lt;/b&gt;每日06:00前&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="130" width="160" height="85" as="geometry" />
        </mxCell>
        <!-- Arrow ①→② -->
        <mxCell id="12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b8a472;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="10" target="20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- STEP 2: 现场巡检执行 -->
        <mxCell id="20" value="&lt;b&gt;② 现场巡检执行&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;按导航路线逐点巡检&lt;br&gt;GPS轨迹记录，AI实时预警" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="55" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="21" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;角色：&lt;/b&gt;巡检员&lt;br&gt;&lt;b&gt;AI：&lt;/b&gt;实时预警&lt;br&gt;&lt;b&gt;GIS：&lt;/b&gt;轨迹记录+实时定位+路线导航&lt;br&gt;&lt;b&gt;SLA：&lt;/b&gt;计划时长内&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="220" y="130" width="160" height="85" as="geometry" />
        </mxCell>
        <!-- Arrow ②→③ -->
        <mxCell id="22" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b8a472;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="20" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- STEP 3: 发现上报 -->
        <mxCell id="30" value="&lt;b&gt;③ 发现上报&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;拍照+语音上报异常&lt;br&gt;AI识别分类，NLP结构化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d5b0;strokeColor=#b8a472;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="410" y="55" width="160" height="65" as="geometry" />
        </mxCell>
        <mxCell id="31" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;角色：&lt;/b&gt;巡检员&lt;br&gt;&lt;b&gt;AI：&lt;/b&gt;图像识别+NLP结构化&lt;br&gt;&lt;b&gt;GIS：&lt;/b&gt;定位打标+空间关联&lt;br&gt;&lt;b&gt;SLA：&lt;/b&gt;≤3min&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="410" y="130" width="160" height="85" as="geometry" />
        </mxCell>
