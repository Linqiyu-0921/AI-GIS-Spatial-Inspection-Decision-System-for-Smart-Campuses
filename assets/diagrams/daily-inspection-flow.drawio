        <mxCell id="50H" value="&lt;b&gt;⑤-严 工单创建分派&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;AI推荐处置人&lt;br&gt;GIS就近匹配" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
