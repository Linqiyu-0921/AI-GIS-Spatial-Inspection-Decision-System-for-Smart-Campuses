        <!-- STEP 5-轻: 当场处置 -->
        <mxCell id="50L" value="&lt;b&gt;⑤-轻 当场处置&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;巡检员现场处理&lt;br&gt;AI图像比对验证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="210" width="160" height="65" as="geometry" />
