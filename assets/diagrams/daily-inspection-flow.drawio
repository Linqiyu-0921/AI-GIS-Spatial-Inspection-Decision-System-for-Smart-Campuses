        <mxCell id="71" value="&lt;div style=&quot;text-align:left;padding:2px;font-size:10px;line-height:14px;&quot;&gt;&lt;b&gt;角色：&lt;/b&gt;巡检员/管理层&lt;br&gt;&lt;b&gt;AI：&lt;/b&gt;图像比对+质量评分&lt;br&gt;&lt;b&gt;GIS：&lt;/b&gt;现场确认&lt;br&gt;&lt;b&gt;SLA：&lt;/b&gt;巡检员≤24h/管理层≤4h&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;arcSize=6;fontSize=10;verticalAlign=top;spacingTop=2;" vertex="1" parent="1">
